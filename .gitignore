# ==========================================
# Liminal AI — .gitignore
# ==========================================

# ─── OS Generated ─────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
*.swp
*.swo

# ─── IDE / Editors ────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ─── Node.js / Frontend ──────────────────
node_modules/
dist/
build/
.npm
.eslintcache
.stylelintcache
.vite-inspect
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Bun ──────────────────────────────────
bun.lockb
bun.lock
.bun-build

# ─── Python / Backend ────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/
backend/.venv/
backend/.python-version
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
*.egg-info/
*.egg

# ─── Environment Variables (CRITICAL) ────
.env
.env.*
*.env
.secret
.secrets

# ─── Databases / Local Storage ───────────
*.db
*.sqlite3
.data/
backend/uploads/

# ─── Documents (local-only assets) ───────
Documents/

# ─── AI Assistant Configs ────────────────
.claude/
.cursor/
CLAUDE.md

# ─── Misc ────────────────────────────────
*.log